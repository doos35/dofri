# Identifiants admin — À changer absolument avant la mise en production
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me

# Secret JWT — Générer avec PowerShell :
# $rng = New-Object System.Security.Cryptography.RNGCryptoServiceProvider; $b = New-Object byte[] 64; $rng.GetBytes($b); [System.BitConverter]::ToString($b).Replace("-","").ToLower()
JWT_SECRET=generate-a-random-64-char-hex-string

# Port du serveur (défaut: 3001)
PORT=3001

# Origines autorisées pour CORS (séparées par virgule si plusieurs)
# En dev : http://localhost:5173
# En prod : https://dofri-client.vercel.app
CLIENT_ORIGIN=http://localhost:5173
