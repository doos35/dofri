# URI MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/link-portal

# Identifiants admin — OBLIGATOIRE, pas de valeur par défaut
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=change-me-strong-password

# Secret JWT (min 32 caractères) — Générer avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate-a-random-96-char-hex-string

# Port du serveur (défaut: 3001)
PORT=3001

# Origines autorisées pour CORS (séparées par virgule si plusieurs)
# En dev : http://localhost:5173
# En prod : https://dofri-client.vercel.app
CLIENT_ORIGIN=http://localhost:5173
